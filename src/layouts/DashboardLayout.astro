---
import "../styles/global.css";

interface Props {
	title: string;
	currentPath?: string;
}

const { title, currentPath = "/" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Dashboard de Gestión de Proyectos" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} — ProjectHub</title>
	</head>
	<body class="flex h-screen overflow-hidden">
		<!-- Sidebar -->
		<aside
			class="w-64 bg-slate-900 border-r border-slate-700/50 flex flex-col shrink-0"
		>
			<!-- Logo -->
			<div class="p-5 border-b border-slate-700/50">
				<a href="/dashboard" class="flex items-center gap-3">
					<div
						class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center"
					>
						<svg
							class="w-5 h-5 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
							></path>
						</svg>
					</div>
					<div>
						<span class="text-slate-100 font-bold text-base leading-tight block"
							>ProjectHub</span
						>
						<span class="text-slate-500 text-xs">Gestión de Proyectos</span>
					</div>
				</a>
			</div>

			<!-- Navigation -->
			<nav class="flex-1 p-3 space-y-1 overflow-y-auto">
				<div class="mb-4">
					<p class="text-xs font-semibold text-slate-600 uppercase tracking-wider px-3 mb-2">
						Principal
					</p>
					<a
						href="/dashboard"
						class={`sidebar-link ${currentPath === "/dashboard" ? "active" : ""}`}
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
						</svg>
						Dashboard
					</a>
					<a
						href="/projects"
						class={`sidebar-link ${currentPath.startsWith("/projects") ? "active" : ""}`}
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
						</svg>
						Proyectos
					</a>
					<a
						href="/kanban"
						class={`sidebar-link ${currentPath === "/kanban" ? "active" : ""}`}
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
						</svg>
						Kanban
					</a>
				</div>

				<div class="mb-4">
					<p class="text-xs font-semibold text-slate-600 uppercase tracking-wider px-3 mb-2">
						Equipo
					</p>
					<a
						href="/team"
						class={`sidebar-link ${currentPath === "/team" ? "active" : ""}`}
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
						</svg>
						Equipo
					</a>
					<a
						href="/reports"
						class={`sidebar-link ${currentPath === "/reports" ? "active" : ""}`}
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
						</svg>
						Reportes
					</a>
				</div>
			</nav>

			<!-- User profile -->
			<div class="p-3 border-t border-slate-700/50">
				<div id="user-info" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-700/50 transition-colors cursor-pointer" onclick="window.location.href='/profile'">
					<div id="user-avatar" class="w-8 h-8 rounded-full bg-indigo-600 flex items-center justify-center text-xs font-bold text-white shrink-0">
						?
					</div>
					<div class="flex-1 min-w-0">
						<p id="user-name" class="text-sm font-medium text-slate-200 truncate">Cargando...</p>
						<p id="user-role" class="text-xs text-slate-500 truncate">—</p>
					</div>
				</div>
				<a
					href="/auth/signout"
					class="flex items-center gap-3 px-3 py-2 mt-1 rounded-lg text-slate-500 hover:text-red-400 hover:bg-red-900/20 transition-all duration-200 text-sm"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
					</svg>
					Cerrar sesión
				</a>
			</div>
		</aside>

		<!-- Main content -->
		<main class="flex-1 overflow-y-auto bg-slate-900/50">
			<slot />
		</main>

		<script>
			import { supabase, ROLE_LABELS } from "../lib/supabase";
			import type { Role } from "../lib/supabase";

			async function loadUserInfo() {
				const { data: { session } } = await supabase.auth.getSession();
				if (!session) return;

				const { data: profile } = await supabase
					.from("profiles")
					.select("*")
					.eq("id", session.user.id)
					.single();

				if (profile) {
					const nameEl = document.getElementById("user-name");
					const roleEl = document.getElementById("user-role");
					const avatarEl = document.getElementById("user-avatar");

					if (nameEl) nameEl.textContent = profile.full_name || session.user.email || "Usuario";
					if (roleEl) roleEl.textContent = ROLE_LABELS[profile.role as Role] || profile.role;
					if (avatarEl) {
						if (profile.avatar_url) {
							avatarEl.innerHTML = `<img src="${profile.avatar_url}" class="w-8 h-8 rounded-full object-cover" alt="Avatar" />`;
						} else {
							const name = profile.full_name || "U";
							avatarEl.textContent = name.charAt(0).toUpperCase();
						}
					}
				}
			}

			loadUserInfo();
		</script>
	</body>
</html>
