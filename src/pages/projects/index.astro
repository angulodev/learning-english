---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import ProjectsManager from "../../components/projects/ProjectsManager";
---

<DashboardLayout title="Proyectos" currentPath="/projects">
	<div class="flex flex-col h-full">
		<div class="px-6 pt-6 pb-2">
			<h1 class="text-2xl font-bold text-slate-100">Proyectos</h1>
			<p class="text-slate-400 text-sm mt-1">Gestiona todos los proyectos de tu equipo</p>
		</div>
		<ProjectsManager client:load />
	</div>
</DashboardLayout>
