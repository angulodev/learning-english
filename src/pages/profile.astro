---
import DashboardLayout from "../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Mi Perfil" currentPath="/profile">
	<div class="p-6 md:p-8 max-w-2xl">
		<div class="mb-8">
			<h1 class="text-2xl font-bold text-slate-100">Mi Perfil</h1>
			<p class="text-slate-400 text-sm mt-1">Tu información y configuración de cuenta</p>
		</div>

		<div id="profile-loading" class="animate-pulse space-y-4">
			<div class="h-24 bg-slate-800 rounded-xl"></div>
			<div class="h-48 bg-slate-800 rounded-xl"></div>
		</div>

		<div id="profile-content" class="hidden space-y-6">
			<!-- Avatar + name -->
			<div class="bg-slate-800 rounded-xl border border-slate-700 p-6">
				<div class="flex items-center gap-5">
					<div id="avatar-container" class="w-16 h-16 rounded-2xl bg-indigo-600 flex items-center justify-center text-xl font-bold text-white shrink-0">?</div>
					<div>
						<h2 id="profile-name" class="text-xl font-bold text-slate-100">—</h2>
						<p id="profile-email" class="text-slate-400 text-sm mt-0.5">—</p>
						<div id="profile-role-badge" class="mt-2"></div>
					</div>
				</div>
			</div>

			<!-- Stats -->
			<div class="grid grid-cols-2 gap-4">
				<div class="bg-slate-800 rounded-xl border border-slate-700 p-5">
					<p class="text-xs text-slate-500 mb-1">Proyectos asignados</p>
					<p id="proj-count" class="text-2xl font-bold text-indigo-400">—</p>
				</div>
				<div class="bg-slate-800 rounded-xl border border-slate-700 p-5">
					<p class="text-xs text-slate-500 mb-1">Tareas activas</p>
					<p id="task-count" class="text-2xl font-bold text-amber-400">—</p>
				</div>
			</div>

			<!-- Info -->
			<div class="bg-slate-800 rounded-xl border border-slate-700 p-6">
				<h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Información de cuenta</h3>
				<div class="space-y-3">
					<div class="flex justify-between">
						<span class="text-sm text-slate-500">Miembro desde</span>
						<span id="joined-date" class="text-sm text-slate-300">—</span>
					</div>
					<div class="flex justify-between">
						<span class="text-sm text-slate-500">Proveedor</span>
						<span class="text-sm text-slate-300">Google OAuth</span>
					</div>
					<div class="flex justify-between">
						<span class="text-sm text-slate-500">Estado</span>
						<span class="badge-green">Activo</span>
					</div>
				</div>
			</div>

			<a href="/auth/signout" class="btn-danger block text-center w-full justify-center">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
				</svg>
				Cerrar sesión
			</a>
		</div>
	</div>

	<script>
		import { supabase, ROLE_LABELS, ROLE_COLORS } from "../lib/supabase";
		import type { Role } from "../lib/supabase";

		const ROLE_BADGE: Record<string, string> = {
			project_leader: "bg-purple-900/40 text-purple-400 border border-purple-700/30",
			pmo: "bg-blue-900/40 text-blue-400 border border-blue-700/30",
			gestor: "bg-emerald-900/40 text-emerald-400 border border-emerald-700/30",
			cliente: "bg-amber-900/40 text-amber-400 border border-amber-700/30",
		};

		async function loadProfile() {
			const { data: { session } } = await supabase.auth.getSession();
			if (!session) return;

			const [{ data: profile }, { data: members }, { data: tasks }] = await Promise.all([
				supabase.from("profiles").select("*").eq("id", session.user.id).single(),
				supabase.from("project_members").select("id").eq("user_id", session.user.id),
				supabase.from("tasks").select("id").eq("assigned_to", session.user.id).in("status", ["todo", "in_progress", "review"]),
			]);

			document.getElementById("profile-loading")!.classList.add("hidden");
			document.getElementById("profile-content")!.classList.remove("hidden");

			if (profile) {
				document.getElementById("profile-name")!.textContent = profile.full_name || "Sin nombre";
				document.getElementById("profile-email")!.textContent = profile.email || "";
				document.getElementById("proj-count")!.textContent = (members?.length || 0).toString();
				document.getElementById("task-count")!.textContent = (tasks?.length || 0).toString();
				document.getElementById("joined-date")!.textContent = new Date(profile.created_at).toLocaleDateString("es", { day: "numeric", month: "long", year: "numeric" });

				const roleEl = document.getElementById("profile-role-badge")!;
				roleEl.innerHTML = `<span class="text-xs px-2.5 py-1 rounded-full ${ROLE_BADGE[profile.role] || ""}">${ROLE_LABELS[profile.role as Role] || profile.role}</span>`;

				const avatarEl = document.getElementById("avatar-container")!;
				if (profile.avatar_url) {
					avatarEl.innerHTML = `<img src="${profile.avatar_url}" class="w-16 h-16 rounded-2xl object-cover" alt="Avatar" />`;
				} else {
					avatarEl.textContent = profile.full_name?.charAt(0).toUpperCase() || "?";
				}
			}
		}

		loadProfile();
	</script>
</DashboardLayout>
