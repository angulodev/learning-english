---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import KanbanBoard from "../components/kanban/KanbanBoard";
---

<DashboardLayout title="Kanban" currentPath="/kanban">
	<div class="flex flex-col h-full">
		<div class="px-6 pt-6 pb-2">
			<h1 class="text-2xl font-bold text-slate-100">Tablero Kanban</h1>
			<p class="text-slate-400 text-sm mt-1">Gestiona las tareas arrastrándolas entre columnas</p>
		</div>
		<div class="flex-1 overflow-hidden">
			<KanbanBoard client:load />
		</div>
	</div>
</DashboardLayout>
