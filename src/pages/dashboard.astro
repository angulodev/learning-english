---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import DashboardCharts from "../components/dashboard/DashboardCharts";
---

<DashboardLayout title="Dashboard" currentPath="/dashboard">
	<div class="p-6 md:p-8 animate-fade-in">
		<!-- Header -->
		<div class="mb-8">
			<h1 class="text-2xl font-bold text-slate-100">Dashboard</h1>
			<p class="text-slate-400 text-sm mt-1">Resumen general de proyectos y equipo</p>
		</div>

		<!-- Stats -->
		<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8" id="stats-container">
			{[
				{ label: "Cargando...", value: "—", icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10", color: "text-indigo-400", bg: "bg-indigo-600/10" },
				{ label: "Cargando...", value: "—", icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2", color: "text-emerald-400", bg: "bg-emerald-600/10" },
				{ label: "Cargando...", value: "—", icon: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z", color: "text-blue-400", bg: "bg-blue-600/10" },
				{ label: "Cargando...", value: "—", icon: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z", color: "text-amber-400", bg: "bg-amber-600/10" },
			].map((stat, i) => (
				<div class="bg-slate-800 rounded-xl border border-slate-700 p-5" data-stat={i}>
					<div class="flex items-start justify-between">
						<div>
							<p class="text-xs text-slate-500 stat-label">{stat.label}</p>
							<p class="text-2xl font-bold text-slate-100 mt-1 stat-value">{stat.value}</p>
						</div>
						<div class={`w-10 h-10 rounded-xl ${stat.bg} flex items-center justify-center shrink-0`}>
							<svg class={`w-5 h-5 ${stat.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={stat.icon} />
							</svg>
						</div>
					</div>
				</div>
			))}
		</div>

		<!-- Charts -->
		<div class="mb-8">
			<h2 class="text-base font-semibold text-slate-300 mb-4">Analítica</h2>
			<DashboardCharts client:load />
		</div>

		<!-- Recent Projects -->
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
			<!-- Recent projects list -->
			<div class="bg-slate-800 rounded-xl border border-slate-700 p-6">
				<div class="flex items-center justify-between mb-5">
					<h2 class="text-sm font-semibold text-slate-300">Proyectos Recientes</h2>
					<a href="/projects" class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors">Ver todos →</a>
				</div>
				<div id="recent-projects" class="space-y-3">
					<div class="animate-pulse space-y-3">
						{[1,2,3].map(() => (
							<div class="h-14 bg-slate-700/50 rounded-lg"></div>
						))}
					</div>
				</div>
			</div>

			<!-- Recent activity -->
			<div class="bg-slate-800 rounded-xl border border-slate-700 p-6">
				<div class="flex items-center justify-between mb-5">
					<h2 class="text-sm font-semibold text-slate-300">Actividad Reciente</h2>
				</div>
				<div id="recent-activity" class="space-y-4">
					<div class="animate-pulse space-y-3">
						{[1,2,3,4].map(() => (
							<div class="h-10 bg-slate-700/50 rounded-lg"></div>
						))}
					</div>
				</div>
			</div>
		</div>
	</div>

	<script>
		import { supabase, STATUS_LABELS, STATUS_COLORS } from "../lib/supabase";
		import type { Project } from "../lib/supabase";

		async function loadStats() {
			const [projectsRes, tasksRes, membersRes, risksRes] = await Promise.all([
				supabase.from("projects").select("id, status"),
				supabase.from("tasks").select("id, status"),
				supabase.from("profiles").select("id"),
				supabase.from("project_risks").select("id, status").eq("status", "identified"),
			]);

			const projects = projectsRes.data || [];
			const tasks = tasksRes.data || [];
			const members = membersRes.data || [];
			const risks = risksRes.data || [];

			const activeProjects = projects.filter((p: any) => p.status === "active").length;
			const doneTasks = tasks.filter((t: any) => t.status === "done").length;

			const cards = document.querySelectorAll("[data-stat]");
			const statData = [
				{ label: "Proyectos Activos", value: activeProjects.toString() },
				{ label: "Tareas Completadas", value: `${doneTasks}/${tasks.length}` },
				{ label: "Miembros del Equipo", value: members.length.toString() },
				{ label: "Riesgos Identificados", value: risks.length.toString() },
			];

			cards.forEach((card, i) => {
				const labelEl = card.querySelector(".stat-label");
				const valueEl = card.querySelector(".stat-value");
				if (labelEl) labelEl.textContent = statData[i].label;
				if (valueEl) valueEl.textContent = statData[i].value;
			});
		}

		async function loadRecentProjects() {
			const { data: projects } = await supabase
				.from("projects")
				.select("*, leader:profiles(full_name)")
				.order("created_at", { ascending: false })
				.limit(5);

			const container = document.getElementById("recent-projects");
			if (!container) return;

			if (!projects || projects.length === 0) {
				container.innerHTML = `<p class="text-slate-500 text-sm text-center py-6">No hay proyectos aún. <a href="/projects/new" class="text-indigo-400 hover:underline">Crear primero</a></p>`;
				return;
			}

			const colorMap: Record<string, string> = {
				planning: "bg-blue-900/50 text-blue-300",
				active: "bg-emerald-900/50 text-emerald-300",
				on_hold: "bg-amber-900/50 text-amber-300",
				completed: "bg-slate-700 text-slate-300",
				cancelled: "bg-red-900/50 text-red-300",
			};

			container.innerHTML = projects.map((p: any) => `
				<a href="/projects/${p.id}" class="flex items-center gap-3 p-3 rounded-lg hover:bg-slate-700/50 transition-colors group">
					<div class="w-9 h-9 bg-indigo-600/20 rounded-lg flex items-center justify-center text-indigo-400 text-xs font-bold shrink-0 group-hover:bg-indigo-600/30 transition-colors">
						${p.code.slice(0, 3).toUpperCase()}
					</div>
					<div class="flex-1 min-w-0">
						<p class="text-sm font-medium text-slate-200 truncate">${p.name}</p>
						<p class="text-xs text-slate-500 truncate">${p.code}</p>
					</div>
					<span class="text-xs px-2 py-0.5 rounded-full ${colorMap[p.status] || "bg-slate-700 text-slate-300"} whitespace-nowrap">
						${STATUS_LABELS[p.status as keyof typeof STATUS_LABELS] || p.status}
					</span>
				</a>
			`).join("");
		}

		async function loadRecentActivity() {
			const { data: comments } = await supabase
				.from("project_comments")
				.select("*, author:profiles(full_name, avatar_url), project:projects(name, code)")
				.order("created_at", { ascending: false })
				.limit(5);

			const container = document.getElementById("recent-activity");
			if (!container) return;

			if (!comments || comments.length === 0) {
				container.innerHTML = `<p class="text-slate-500 text-sm text-center py-6">Sin actividad reciente</p>`;
				return;
			}

			container.innerHTML = comments.map((c: any) => {
				const name = c.author?.full_name || "Usuario";
				const initial = name.charAt(0).toUpperCase();
				const time = new Date(c.created_at).toLocaleDateString("es", { day: "numeric", month: "short" });
				return `
					<div class="flex items-start gap-3">
						<div class="w-7 h-7 rounded-full bg-indigo-600 flex items-center justify-center text-xs font-bold text-white shrink-0">
							${c.author?.avatar_url ? `<img src="${c.author.avatar_url}" class="w-7 h-7 rounded-full object-cover" />` : initial}
						</div>
						<div class="flex-1 min-w-0">
							<p class="text-xs text-slate-400"><span class="font-medium text-slate-300">${name}</span> comentó en <span class="text-indigo-400">${c.project?.name || "—"}</span></p>
							<p class="text-xs text-slate-600 truncate mt-0.5">${c.content}</p>
						</div>
						<span class="text-xs text-slate-600 whitespace-nowrap">${time}</span>
					</div>
				`;
			}).join("");
		}

		loadStats();
		loadRecentProjects();
		loadRecentActivity();
	</script>
</DashboardLayout>
